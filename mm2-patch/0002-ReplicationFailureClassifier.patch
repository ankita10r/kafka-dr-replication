+package org.apache.kafka.connect.mirror;
+
+import org.apache.kafka.common.Uuid;
+
+/**
+ * Decides whether an {@code OffsetOutOfRangeException} represents a genuine data-loss
+ * event (retention purged data MirrorMaker 2 hadn't replicated yet) or a benign topic
+ * reset (the topic was deleted and recreated), based on whether the topic's UUID has
+ * changed since it was last observed.
+ *
+ * <p>Deliberately free of any Kafka Connect, consumer, or AdminClient dependency --
+ * takes two {@link Uuid} values in, returns a decision out. This is what makes it
+ * unit-testable without a broker (see {@code ReplicationFailureClassifierTest}); all
+ * the I/O (fetching the current UUID, caching the previous one, acting on the
+ * decision) stays in {@link MirrorSourceTask}.
+ */
+public class ReplicationFailureClassifier {
+
+    public enum Decision {
+        TOPIC_RESET,
+        DATA_LOSS
+    }
+
+    /**
+     * @param previousTopicId the topic's UUID as last cached, or {@code null} if never observed
+     * @param currentTopicId  the topic's UUID as just fetched, or {@code null} if the fetch failed
+     */
+    public Decision classify(Uuid previousTopicId, Uuid currentTopicId) {
+        boolean bothKnownAndDifferent = previousTopicId != null
+                && currentTopicId != null
+                && !previousTopicId.equals(currentTopicId);
+
+        if (bothKnownAndDifferent) {
+            return Decision.TOPIC_RESET;
+        }
+        // Same ID, or either ID couldn't be established -- in every case where we can't
+        // positively prove this is a benign reset, treat it as data loss.
+        return Decision.DATA_LOSS;
+    }
+}
