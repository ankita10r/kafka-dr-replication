+package org.apache.kafka.connect.mirror;
+
+/**
+ * Thrown by {@link MirrorSourceTask} when it detects that the next offset it expected
+ * to consume has been removed from the source topic-partition (e.g. by retention-based
+ * log truncation) without having been replicated. This represents an unrecoverable,
+ * silent-data-loss condition for the affected partition, distinct from a topic
+ * delete+recreate (see {@link MirrorSourceTask} reset-handling logic), and causes the
+ * task to fail fast rather than silently skip ahead.
+ */
+public class MirrorDataLossException extends RuntimeException {
+
+    private static final long serialVersionUID = 1L;
+
+    public MirrorDataLossException(String message) {
+        super(message);
+    }
+}
